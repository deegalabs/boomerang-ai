# Boomerang AI — copy to .env and fill in. NEVER commit .env.
# ───────────────────────────────────────────────────────────────

# Agent wallet (generated locally — self-custody).
# In production, prefer the bnbagent keystore (EVMWalletProvider) over a raw key.
AGENT_PRIVATE_KEY=
WALLET_PASSWORD=

# Owner's personal wallet — destination of the withdraw / boomerang return.
OWNER_WALLET_ADDRESS=

# Trust Wallet Agent Kit (portal.trustwallet.com → create app → API key)
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# CoinMarketCap — x402 pays $0.01/req in USDC on the BASE network (not BSC).
# If using subscription MCP instead of x402, provide the API key.
CMC_API_KEY=

# LLM brain (Claude)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_MASTER_USER_ID=

# Optional anti-MEV RPC (overrides the one in config.json)
BSC_RPC_URL=

# Read-only web dashboard (access token delivered by /dashboard on Telegram)
DASHBOARD_TOKEN=
DASHBOARD_PORT=8080
DASHBOARD_BASE_URL=http://localhost:8080

# ERC-8004 identity (on-chain attestation: prediction commit, track record, risk state).
# The identity keystore (identity_wallet/) is git-ignored and NOT shipped to the container,
# so PRODUCTION must inject the private key of the wallet that OWNS the agentId — otherwise
# set_metadata reverts "Not authorized". Export it locally with the keystore + password:
#   python scripts/export_identity_key.py
# then set the value as a secret in production. (Identity wallet holds NO funds; gas-free.)
BNB_IDENTITY_PRIVATE_KEY=
BNB_IDENTITY_PASSWORD=
