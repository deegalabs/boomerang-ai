# Boomerang AI — copie para .env e preencha. NUNCA commite o .env.
# ───────────────────────────────────────────────────────────────

# Carteira do agente (gerada localmente — autocustódia).
# Em produção, preferir keystore do bnbagent (EVMWalletProvider) a chave crua.
AGENT_PRIVATE_KEY=
WALLET_PASSWORD=

# Carteira pessoal do dono — destino do saque / boomerang return.
OWNER_WALLET_ADDRESS=

# Trust Wallet Agent Kit (portal.trustwallet.com → criar app → API key)
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# CoinMarketCap — x402 paga $0.01/req em USDC na rede BASE (não BSC).
# Se usar MCP por assinatura em vez de x402, informar a API key.
CMC_API_KEY=

# Cérebro LLM (Claude)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_MASTER_USER_ID=

# RPC opcional com proteção anti-MEV (sobrescreve o do config.json)
BSC_RPC_URL=

# Dashboard web só-leitura (token de acesso entregue pelo /dashboard no Telegram)
DASHBOARD_TOKEN=
DASHBOARD_PORT=8080
DASHBOARD_BASE_URL=http://localhost:8080
